# ── Local development ────────────────────────────────────────────────────────
# Copy to .env and adjust as needed.
# docker-compose up -d starts Postgres with these exact credentials.

# Database (local Docker)
DATABASE_URL="postgresql://brp:brp@localhost:5432/brp"

# Server port
PORT=3001

# Cron schedule for syncing from CityBikes API (default: every 5 min)
SYNC_INTERVAL_CRON="*/5 * * * *"

# Frontend — Vite reads VITE_ prefix
# Leave empty to fall back to the public CityBikes API
VITE_API_URL=http://localhost:3001


# ── Railway (backend) env vars ────────────────────────────────────────────────
# Set these in the Railway dashboard → Service → Variables:
#
#   DATABASE_URL        → Railway will inject this automatically if you add a
#                         Postgres plugin to the same project
#   PORT                → Railway sets $PORT automatically; you don't need this
#   SYNC_INTERVAL_CRON  → optional, defaults to "*/5 * * * *"


# ── Vercel (frontend) env vars ────────────────────────────────────────────────
# Set these in the Vercel dashboard → Project → Settings → Environment Variables:
#
#   VITE_API_URL  → https://your-railway-service.up.railway.app
