    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
